@page "/flags"
@using ProcGenFun.Blazor.Components
@using ProcGenFun.Distributions
@using ProcGenFun.Flags
@using ProcGenFun.Flags.Generation
@using ProcGenFun.Flags.Images
@using RandN
@using RandN.Extensions
@using Svg
@inject IJSRuntime JS

<PageTitle>Flags</PageTitle>

<Title>Flags</Title>

<div class="flex justify-center">
  <Button OnClick="GenerateFlags" Style=Button.ButtonStyle.Filled Size=Button.ButtonSize.Medium>Generate Flags</Button>
</div>

<div class="grid grid-cols-2 sm:grid-cols-3 my-8 gap-8">
  @foreach (var flagImage in this.flagImages)
  {
    <div class="flex flex-col items-end gap-2">
      <div>
        @((MarkupString)flagImage.GetXML())
      </div>
      <div class="flex gap-2">
        <Button OnClick="async () => await ShareFlag(flagImage)" Style=Button.ButtonStyle.Outline
                Size=Button.ButtonSize.Small>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path
            d="M13.5 1a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3M11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.5 2.5 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5m-8.5 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3m11 5.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3" />
          </svg>
        </Button>
        <Button OnClick="async () => await DownloadFlag(flagImage)" Style=Button.ButtonStyle.Outline
                Size=Button.ButtonSize.Small>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path
              d="M4.406 1.342A5.53 5.53 0 0 1 8 0c2.69 0 4.923 2 5.166 4.579C14.758 4.804 16 6.137 16 7.773 16 9.569 14.502 11 12.687 11H10a.5.5 0 0 1 0-1h2.688C13.979 10 15 8.988 15 7.773c0-1.216-1.02-2.228-2.313-2.228h-.5v-.5C12.188 2.825 10.328 1 8 1a4.53 4.53 0 0 0-2.941 1.1c-.757.652-1.153 1.438-1.153 2.055v.448l-.445.049C2.064 4.805 1 5.952 1 7.318 1 8.785 2.23 10 3.781 10H6a.5.5 0 0 1 0 1H3.781C1.708 11 0 9.366 0 7.318c0-1.763 1.266-3.223 2.942-3.593.143-.863.698-1.723 1.464-2.383">
            </path>
            <path
              d="M7.646 15.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 14.293V5.5a.5.5 0 0 0-1 0v8.793l-2.146-2.147a.5.5 0 0 0-.708.708z">
            </path>
          </svg>
        </Button>
      </div>
    </div>
  }
</div>

@code {
  private readonly IRng rng = StandardRng.Create();
  private IEnumerable<SvgDocument> flagImages = [];

  public void GenerateFlags()
  {
    var flagImageDist =
        from flag in FlagCreator.FlagDist()
        select FlagImage.CreateSvg(flag, className: "shadow-2xl w-full");

    var flagImagesDist =
        from flagImages in flagImageDist.Repeat(6)
        select flagImages.ToReadOnly();

    this.flagImages = flagImagesDist.Sample(this.rng);
  }

  private async Task ShareFlag(SvgDocument flagImage)
  {
    try
    {
      var svgContent = flagImage.GetXML();
      await JS.InvokeVoidAsync("shareUtils.shareFlag", svgContent);
    }
    catch (Exception ex)
    {
      Console.WriteLine($"Error sharing flag: {ex.Message}");
    }
  }

  private async Task DownloadFlag(SvgDocument flagImage)
  {
    try
    {
      var svgContent = flagImage.GetXML();
      await JS.InvokeVoidAsync("shareUtils.downloadFlag", svgContent);
    }
    catch (Exception ex)
    {
      Console.WriteLine($"Error downloading flag: {ex.Message}");
    }
  }
}